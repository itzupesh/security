name: Secret Security Test
on:
  pull_request:
    types: [opened, synchronize]

jobs:
  leak-check:
    runs-on: ubuntu-latest
    steps:
      - name: Leak Secret via Base64
        env:
          MY_SECRET: ${{ secrets.TEST_SECRET }}
        run: |
          # We encode it to bypass the log scrubber '***'
          echo "Encoded secret: $(echo -n "$MY_SECRET" | base64)"
